{
  "name": "pantheon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A personal daily-learning app. One theme a day, six resonant facets.",
  "scripts": {
    "predev": "tsx scripts/build-manifest.ts && tsx scripts/validate.ts",
    "dev": "vite",
    "studio": "vite --open /studio.html",
    "studio:report": "tsx scripts/studio-report.ts",
    "prebuild": "tsx scripts/build-manifest.ts && tsx scripts/validate.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx scripts/validate.ts",
    "build-manifest": "tsx scripts/build-manifest.ts",
    "ingest-images": "tsx scripts/ingest-images.ts",
    "sync": "tsx scripts/sync.ts",
    "map": "tsx scripts/map.ts",
    "scout": "tsx scripts/scout.ts",
    "deep": "tsx scripts/deep.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
