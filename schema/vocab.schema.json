{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pantheon.local/schema/vocab.schema.json",
  "title": "Pantheon Controlled Vocabulary",
  "type": "object",
  "required": ["registers", "regions", "eras"],
  "additionalProperties": false,
  "properties": {
    "registers": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["elegy", "redemption", "defiance", "tenderness", "comedy", "awe"] }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "eras": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 },
          "from": { "type": "integer" },
          "to": { "type": "integer" }
        }
      }
    }
  }
}
